<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Creative CV  - Website Template</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="m-0 p-0 bg-white">
    {{> header}}

    <div id="analytics-script" aria-hidden="true" class="hidden"></div>
    <div id="localization-config" aria-hidden="true" class="hidden"></div>

    <main class="pt-[72px]">
      <section class="w-full bg-[#f5f5f5] border-b border-[#e5e5e5]">
        <div class="max-w-[1440px] mx-auto px-4 md:px-8 py-6 md:py-8 text-[#162d3d]">
          <h3 class="text-[14px] leading-[20px] font-semibold">Good For:</h3>
          <p class="text-[14px] leading-[20px] mt-1">CVs, resumes and portfolios</p>
          <h3 class="text-[14px] leading-[20px] font-semibold mt-4">Description:</h3>
          <p class="text-[14px] leading-[20px] mt-1">
            Draw attention to your skills and experience with this professional template. This is the perfect place to
            highlight your qualifications, show off past projects and give a little insight on what makes
          </p>
          <p class="text-[14px] leading-[20px] mt-3">Click edit and create your own amazing website</p>
          <div class="mt-4 flex flex-wrap items-center gap-4 text-[14px] leading-[20px]">
            <a href="/" class="underline">wix.com</a>
            <a href="#" class="underline">Read More</a>
            <a href="{{wixEditUrl}}" class="px-4 py-2 bg-[#116dff] text-white no-underline">Edit Now</a>
          </div>
        </div>
      </section>

      <section class="w-full bg-white">
        <div class="hidden md:block w-full">
          <img src="{{fullRef}}" alt="Creative CV desktop reference" class="w-full h-auto block" />
        </div>
        <div class="block md:hidden w-full">
          <img src="{{mobileRef}}" alt="Creative CV mobile reference" class="w-full h-auto block" />
        </div>
      </section>
    </main>

    {{> footer}}

    <script>
      (function () {
        var menuToggle = document.getElementById('mobile-menu-toggle');
        var closeMenu = document.getElementById('close-menu');
        var panel = document.getElementById('mobile-menu-panel');
        if (!menuToggle || !panel) return;
        menuToggle.addEventListener('click', function () {
          panel.classList.toggle('hidden');
        });
        if (closeMenu) {
          closeMenu.addEventListener('click', function () {
            panel.classList.add('hidden');
          });
        }
      })();
    </script>
  </body>
</html>
