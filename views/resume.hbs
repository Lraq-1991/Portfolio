<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-gray-100 font-sans antialiased flex flex-col min-h-screen">
    
    <nav class="bg-gray-800 p-6 flex justify-between items-center shadow-md">
        <div class="text-2xl font-bold tracking-tight">DevPortfolio.</div>
        <div class="space-x-6">
            <a href="/" class="hover:text-blue-400 transition">Home</a>
            <a href="/resume" class="text-blue-400 font-semibold">Resume</a>
            <a href="/projects" class="hover:text-blue-400 transition">Projects</a>
            <a href="/contact" class="hover:text-blue-400 transition">Contact</a>
        </div>
    </nav>

    <main class="flex-grow p-10 max-w-4xl mx-auto w-full">
        <h1 class="text-4xl font-bold border-b border-gray-700 pb-4 mb-8">Experience & Education</h1>
        
        <div class="space-y-8">
            <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
