<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-gray-100 font-sans antialiased flex flex-col min-h-screen">
    
    <nav class="bg-gray-800 p-6 flex justify-between items-center shadow-md">
        <div class="text-2xl font-bold tracking-tight">DevPortfolio.</div>
        <div class="space-x-6">
            <a href="/" class="hover:text-blue-400 transition">Home</a>
            <a href="/resume" class="hover:text-blue-400 transition">Resume</a>
            <a href="/projects" class="hover:text-blue-400 transition">Projects</a>
            <a href="/contact" class="text-blue-400 font-semibold">Contact</a>
        </div>
    </nav>

    <main class="flex-grow p-10 max-w-2xl mx-auto w-full">
        <h1 class="text-4xl font-bold border-b border-gray-700 pb-4 mb-8">Get In Touch</h1>
        
        <form class="bg-gray-800 p-8 rounded-lg shadow-lg space-y-6">
            <div>
                <label class="block text-gray-400 text-sm font-bold mb-2" for="name">Name</label>
                <input class="w-full bg-gray-900 border border-gray-700 text-gray-200 rounded py-3 px-4 focus:outline-none focus:border-blue-500" id="name" type="text" placeholder="Jane Doe">
            </div>
            <div>
                <label class="block text-gray-400 text-sm font-bold mb-2" for="email">Email</label>
                <input class="w-full bg-gray-900 border border-gray-700 text-gray-200 rounded py-3 px-4 focus:outline-none focus:border-blue-500" id="email" type="email" placeholder="jane@example.com">
            </div>
            <div>
                <label class="block text-gray-400 text-sm font-bold mb-2" for="message">Message</label>
                <textarea class="w-full bg-gray-900 border border-gray-700 text-gray-200 rounded py-3 px-4 focus:outline-none focus:border-blue-500 h-32" id="message" placeholder="How can we work together?"></textarea>
            </div>
            <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded transition" type="button">
                Send Message
            </button>
        </form>
    </main>

    <footer class="bg-gray-800 text-center p-6 text-gray-500 text-sm">
        &copy; 2026 DevPortfolio. Built with NestJS & Tailwind.
    </footer>
</body>
</html>