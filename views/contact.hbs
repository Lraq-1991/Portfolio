{{> shell-start}}
{{> header}}
<main class="flex-1 pb-16">
  <div class="mx-auto max-w-7xl w-25vw">

      <section class="min-h-[50%] py-20 px-10">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row gap-16 md:gap-24">

      <div class="md:w-2/5">
        <h1 class="text-4xl font-bold mb-4">Contato</h1>
        <p class="text-gray-700 mb-12">Estou ansioso para receber notícias suas</p>

        <div class="space-y-8">
          <div>
            <p class="font-bold mb-1">Celular</p>
            <p class="text-gray-700">+55 (47) 996591907</p>
          </div>
          <div>
            <p class="font-bold mb-1">Email</p>
            <p class="text-gray-700">alvarezquinteroluis@gmail.com</p>
          </div>
        </div>
      </div>

      <div class="md:flex-1">
        <form 
          class="space-y-6" 
          id="contactForm"
        >
          
          <label class="block text-sm text-gray-700">Assunto</label>
          
          <div class="grid grid-cols-2 gap-4"> 

            <div>
              <input 
                type="text" 
                id="emailSubject" 
                name="subject" 
                placeholder="Escreva seu assunto..." 
                class="w-full bg-white border border-black p-2 focus:outline-none" 
              required/>
            </div>

            <div>
              <input type="reset" value="" class="reset-btn cursor-pointer w-10 bg-white border border-black p-2">
            </div>

          </div><br>

          <div>
            <label class="block text-sm text-gray-700 mb-1">Mensagem</label><br>
              <textarea 
                type="text" 
                name="body" 
                id="emailPayload" 
                rows="8" 
                class="w-full bg-white border border-black p-2 focus:outline-none"
              ></textarea>        
          </div>

          <div class="flex justify-center pt-2">
            <input 
              type="submit" 
              class="w-full max-w-md py-3 bg-[#F2A900] rounded-full font-bold text-black cursor-pointer"
            >
            </input>
          </div>

        </form>

      </div>
    </div>
  </section>

  </div>
</main>

<style>
  .reset-btn{
  background-image: url('undo.png');
  background-size: 20px;
  background-position: center;
  background-repeat: no-repeat;
  }
</style>


<script>

  document.getElementById('contactForm').addEventListener('submit', function(event) {
  // Prevent page from refreshing
  event.preventDefault();

  // 1. Extract values from the form inputs
  const subject = document.getElementById('emailSubject').value;
  const payload = document.getElementById('emailPayload').value;

  // 2. Define email envelope settings
  const recipient = "alvarezquinteroluis@gmail.com";

  // 3. Encode strings safely to format special characters and line breaks
  const encodedSubject = encodeURIComponent(subject);
  const encodedBody = encodeURIComponent(payload);

  // 4. Open the native email client with pre-filled fields
  window.location.href = `mailto:${recipient}?subject=${encodedSubject}&body=${encodedBody}`;
});

</script>

{{> footer}}
{{> shell-end}}
