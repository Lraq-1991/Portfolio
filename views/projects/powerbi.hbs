// DAX functions template
async function DAXFunctions() {
    const html = 
`
        <iframe 
            title="DAXfunctions" 
            style="width: 100%; height: 100%;"
            src="../assets/dax_functions.pdf" 
            frameborder="0" 
            allowFullScreen="true"
        ></iframe>
        `

    return html
