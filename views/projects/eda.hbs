{{> shell-start}}
{{> header}}
<main class="mt-2 font-avenir text-body leading-[1.6em] text-ink w-full h-full flex-grow">
    <div class="flex justify-around w-full grow h-[calc(100vh-20vh)] px-4">

{{!-- Mobile Sidebar --}} 
      
    <sider id="mobile-sider" class="sticky top-0 left-0 right-0 bg-inherit shadow-sm mobile-sider-hidden md:hidden lg:hidden">
      <div id = "mobile-side-toggle" class="px-1 cursor-pointer font-bold">></div>
      <div id="mobile-nb-list" class="border-t border-divider bg-page px-10 py-4 mobile-nb-list-hidden">
        <h4 class="text-xl font-bold">Notebooks</h4>
            <ul class="list-none px-4 font-avenir text-body text-ink gap-4">
              <li class="py-2 px-4 cursor-pointer my-2 list-button" data-text="0">Data Cleaning</li>
              <li class="py-2 px-4 cursor-pointer my-2 list-button" data-text="1">EDA</li>
            </ul>
          </div>
    </sider>

{{!-- End Sidebar --}}      

      <div class="w-1/5 px-4 border-r border-r-gray-300 hidden lg:block md:block">
        <h4 class="text-xl font-bold">Notebooks</h4>
        <ul class="list-none px-auto font-avenir text-body text-ink gap-4">
          <li class="py-2 px-4 cursor-pointer my-2 list-button" data-text="0">Data Cleaning</li>
          <li class="py-2 px-4 cursor-pointer my-2 list-button" data-text="1">EDA</li>
        </ul>
      </div>
      <div id="mobile-content" class="w-4/5 px-4 flex flex-col items-center justify-around h-full gap-4 grow mobile-content">
        <div class="text-2xl font-bold">Read-Only Data Analysis Presentations</div>
        <div class="bg-white border border-gray-300 h-5/6 w-full overflow-auto" id="project-content"></div>
      </div>
  </div>   
</main>

<style>

.mobile-sider-hidden {
    width: 5px;
  }

  .mobile-sider {
    width: screen;
    z-index: 50;
  }

  .mobile-nb-list-hidden {
    display: none;
  }

  .mobile-nb-list {
    display: block;
    width: 100%;
  }

  .mobile-content {
    display: block;
  }

  .mobile-content-hidden {
    display: none;
  }
</style>

<script>

  // Mobile sidebar
  document.getElementById('mobile-side-toggle').addEventListener('click', function() {
    
    if (this.textContent === '>') {
      this.textContent = 'X';
      document.getElementById('mobile-sider').classList.remove('mobile-sider-hidden');
      document.getElementById('mobile-sider').classList.add('mobile-sider');
      document.getElementById('mobile-nb-list').classList.remove('mobile-nb-list-hidden');
      document.getElementById('mobile-nb-list').classList.add('mobile-nb-list');
      document.getElementById('mobile-content').classList.remove('mobile-content');
      document.getElementById('mobile-content').classList.add('mobile-content-hidden');
    } else {
      this.textContent = '>';
      document.getElementById('mobile-sider').classList.remove('mobile-sider');
      document.getElementById('mobile-sider').classList.add('mobile-sider-hidden');
      document.getElementById('mobile-nb-list').classList.remove('mobile-nb-list');
      document.getElementById('mobile-nb-list').classList.add('mobile-nb-list-hidden');
      document.getElementById('mobile-content').classList.remove('mobile-content-hidden');
      document.getElementById('mobile-content').classList.add('mobile-content');
    }

  })

// Fetching templates
async function CleanDataHTML() {
  const response = await fetch('/assets/cleaning_data.html');
  const html = await response.text();

  return html;

}

async function EDAHTML() {
  const response = await fetch('/assets/EDA.html');
  const html = await response.text();

  return html;

}

// Object of templates
const data = [
  {
    title: "Data Cleaning",
    htmlContent: CleanDataHTML()
  },
  {
    title: "EDA",
    htmlContent: EDAHTML()
  },
];


// First load
async function onLoad() {

  document.getElementById('project-content').innerHTML = `
    <p class="mt-2 font-avenir text-body leading-[1.6em] text-ink">${await data[0].htmlContent}</p>
  `;

  document.querySelector('.list-button').style.backgroundColor = '#C0C0C0';

}

onLoad();


// Get list buttons
const buttons = document.querySelectorAll('.list-button');

// Alter content based on list button
buttons.forEach(button => {
  button.addEventListener('click', async function() {

    
    buttons.forEach(button => {
        button.style.backgroundColor = '';
      });

    this.style.backgroundColor = '#C0C0C0';

    const text = this.getAttribute('data-text');

    document.getElementById('project-content').innerHTML = `
    <p class="mt-2 font-avenir text-body leading-[1.6em] text-ink">${await data[text].htmlContent}</p>
    `;

  });
});

</script>
{{> footer}}
{{> shell-end}}