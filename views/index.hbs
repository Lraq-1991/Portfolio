{{> shell-start}}
{{> header}}
<main class="flex-1">
  <div class="mx-auto  px-10 pb-16">
    <div class="flex flex-col items-center gap-10 w-full pt-[135px] lg:flex-row lg:items-start lg:justify-center lg:gap-[33px]">
      <div class="shrink-0 lg:ml-[9px]">
        <div class="block 
        lg:h-[480px] lg:w-[480px]
        md:h-[380px] lg:w-[380px]
        lg:h-[280px] lg:w-[280px] 
        overflow-hidden rounded-full" 
        aria-label="Homepage">
          <img
            src="/profile.jpeg"
            width="480"
            height="480"
            alt="this photo"
            class="h-full w-full object-cover"
            fetchpriority="high"
          />
        </div>
      </div>
      <div class="m-w-2/5 lg:pt-9">
        <h1 class="font-worksansSemi text-hello tracking-[-0.02em] text-ink">Olá</h1>
        <p class="mt-2 font-worksansSemi text-navname text-ink">Um Pouco Sobre Mim</p>
        <p class="mt-2 font-avenir text-body leading-[1.6em] text-ink">
          Sou um profissional de TI morando no sul do Brasil. <br> 
          Minha especialidade é o processamento de dados e a extração de insights a partir deles. <br>
          Acredito que, para alcançar qualquer objetivo, é preciso saber trabalhar em equipe
        </p>
        <div class="mt-10 flex flex-row flex-wrap gap-[17px]">
          <a
            href="/resume"
            class="inline-flex h-[140px] w-[140px] flex-shrink-0 items-center justify-center rounded-full border border-orangeBorder bg-orange font-worksansSemi text-navname text-ink no-underline transition-[border-color,background-color] duration-[400ms] hover:border-ink hover:bg-page"
            aria-label="Resume"
            >Resumo</a
          >
          <a
            href="/projects"
            class="inline-flex h-[140px] w-[140px] flex-shrink-0 items-center justify-center rounded-full border border-coralBorder bg-coral font-worksansSemi text-navname text-ink no-underline transition-[border-color,background-color] duration-[400ms] hover:border-ink hover:bg-page"
            aria-label="Projects"
            >Projetos</a
          >
          <a
            href="/contact"
            class="inline-flex h-[140px] w-[140px] flex-shrink-0 items-center justify-center rounded-full border border-tealBorder bg-teal font-worksansSemi text-navname text-ink no-underline transition-[border-color,background-color] duration-[400ms] hover:border-ink hover:bg-page"
            aria-label="Contact"
            >Contato</a
          >
        </div>
      </div>
    </div>
  </div>
</main>
{{> footer}}
{{> shell-end}}
