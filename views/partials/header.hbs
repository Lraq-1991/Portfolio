<header class="w-full">
  <div class="mx-auto flex w-full min-h-[79px] items-center justify-between px-10">
    <div class="flex min-w-0 flex-1 items-center gap-3">
      <a href="/" class="flex shrink-0 items-center" aria-label="Homepage">
        <span class="inline-block h-[25px] w-[25px] rounded-full bg-[#EEA302]" aria-hidden="true"></span>
      </a>
      <div class="flex min-w-0 flex-wrap items-baseline gap-3">
        <a href="/" class="font-worksansSemi text-navname leading-none text-ink no-underline">Luis Alvarez</a>
        <span class="font-avenir text-body leading-[1.4em] text-ink">Profissional de Dados e TI</span>
      </div>
    </div>
    <nav class="hidden md:block" aria-label="Site">
      <ul class="flex items-center">
        <li class="border-l border-ink first:border-l-0">
          <a
            href="/resume"
            class="{{#eq active 'resume'}}font-semibold {{/eq}}inline-block px-[10px] font-avenir text-body leading-[1.4em] text-ink no-underline transition-colors duration-[400ms] hover:text-navHover"
            {{#eq active 'resume'}}aria-current="page"{{/eq}}
            >Resumo</a
          >
        </li>
        <li class="border-l border-ink first:border-l-0">
          <a
            href="/projects"
            class="{{#eq active 'projects'}}font-semibold {{/eq}}inline-block px-[10px] font-avenir text-body leading-[1.4em] text-ink no-underline transition-colors duration-[400ms] hover:text-navHover"
            {{#eq active 'projects'}}aria-current="page"{{/eq}}
            >Projetos</a
          >
        </li>
        <li class="border-l border-ink first:border-l-0">
          <a
            href="/contact"
            class="{{#eq active 'contact'}}font-semibold {{/eq}}inline-block px-[10px] font-avenir text-body leading-[1.4em] text-ink no-underline transition-colors duration-[400ms] hover:text-navHover"
            {{#eq active 'contact'}}aria-current="page"{{/eq}}
            >Contato</a
          >
        </li>
      </ul>
    </nav>
    <button
      type="button"
      id="mobile-menu-btn"
      class="flex h-11 w-11 shrink-0 items-center justify-center border border-ink md:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      aria-label="Open menu"
    >
      <svg width="20" height="14" viewBox="0 0 20 14" class="text-ink" aria-hidden="true">
        <rect width="20" height="2" fill="currentColor" />
        <rect y="6" width="20" height="2" fill="currentColor" />
        <rect y="12" width="20" height="2" fill="currentColor" />
      </svg>
    </button>
  </div>
  <div id="mobile-nav-panel" class="hidden border-t border-divider bg-page px-10 py-4 md:hidden">
    <ul class="flex flex-col gap-3 font-avenir text-body leading-[1.4em]">
      <li><a class="text-ink no-underline hover:text-navHover" href="/resume">Resume</a></li>
      <li><a class="text-ink no-underline hover:text-navHover" href="/projects">Projects</a></li>
      <li><a class="text-ink no-underline hover:text-navHover" href="/contact">Contact</a></li>
    </ul>
  </div>
</header>
