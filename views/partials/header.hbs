<header class="w-full bg-[#f5f5f5] border-b border-[#e5e5e5] fixed top-0 left-0 right-0 z-50">
  <div class="max-w-[1440px] mx-auto px-4 md:px-8 h-[72px] flex items-center justify-between">
    <div class="flex items-center gap-3 min-w-0">
      <button
        id="mobile-menu-toggle"
        class="md:hidden text-[#162d3d] w-10 h-10 flex items-center justify-center"
        aria-label="show mobile view"
      >
        <span class="inline-block w-5 h-[2px] bg-current relative before:content-[''] before:absolute before:w-5 before:h-[2px] before:bg-current before:-top-1.5 after:content-[''] after:absolute after:w-5 after:h-[2px] after:bg-current after:top-1.5"></span>
      </button>
      <div class="truncate">
        <h1 class="text-[#162d3d] text-[18px] leading-[24px] font-medium truncate">Creative CV  - Website Template</h1>
      </div>
    </div>

    <div class="hidden md:flex items-center gap-4 text-[14px] leading-[20px] text-[#162d3d]">
      <button type="button" class="px-3 py-2 border border-[#dcdcdc] bg-white text-[#162d3d]">show desktop view</button>
      <button type="button" class="px-3 py-2 border border-[#dcdcdc] bg-white text-[#162d3d]">.mobile-new-ui_svg__st1{fill:currentColor}show mobile view</button>
      <a href="{{wixEditUrl}}" class="px-4 py-2 bg-[#116dff] text-white">Edit this site</a>
    </div>
  </div>

  <div id="mobile-menu-panel" class="hidden md:hidden border-t border-[#e5e5e5] bg-[#f5f5f5] px-4 py-4">
    <div class="space-y-3 text-[#162d3d]">
      <h3 class="text-[14px] leading-[20px] font-semibold">Good For:</h3>
      <p class="text-[14px] leading-[20px]">CVs, resumes and portfolios</p>
      <h3 class="text-[14px] leading-[20px] font-semibold">Description:</h3>
      <p class="text-[14px] leading-[20px]">
        Draw attention to your skills and experience with this professional template. This is the perfect place to
        highlight your qualifications, show off past projects and give a little insight on what makes
      </p>
      <p class="text-[14px] leading-[20px]">Click edit and create your own amazing website</p>
      <div class="flex flex-wrap gap-2 pt-2">
        <a href="/" class="underline">wix.com</a>
        <a href="#" class="underline">Read More</a>
        <a href="{{wixEditUrl}}" class="px-4 py-2 bg-[#116dff] text-white">Edit Now</a>
        <button id="close-menu" type="button" class="px-3 py-2 border border-[#dcdcdc] bg-white">close info popup</button>
      </div>
    </div>
  </div>
</header>
